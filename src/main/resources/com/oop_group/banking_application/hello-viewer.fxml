<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:controller="com.oop_group.banking_application.HelloController" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="headerLabel" text="Bank of The Future">
               <font><Font name="Avenir Book" size="23.0" /></font>
               <HBox.margin><Insets left="20.0" /></HBox.margin>
            </Label>
            <Pane HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleLogout" text="Logout">
               <HBox.margin><Insets right="20.0" /></HBox.margin>
            </Button>
         </children>
      </HBox>
   </top>
   <left>
      <VBox fx:id="navSidebar" prefHeight="200.0" prefWidth="150.0" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#handleCheckingBtn" prefWidth="130.0" text="Checking">
               <VBox.margin><Insets bottom="10.0" left="10.0" top="10.0" /></VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#handleSavingsBtn" prefWidth="130.0" text="Savings">
               <VBox.margin><Insets bottom="10.0" left="10.0" /></VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#handleMoneyMarketBtn" prefWidth="130.0" text="Money Market">
               <VBox.margin><Insets bottom="10.0" left="10.0" /></VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
      <ScrollPane fitToWidth="true" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <content>
            <VBox fx:id="accountDisplayArea" spacing="15.0">
               <children>
                  <Label fx:id="typeLabel" text="Account Overview">
                     <font><Font name="System Bold" size="18.0" /></font>
                  </Label>
                  <GridPane hgap="10.0" vgap="10.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <Label text="Account Number:" />
                        <Label text="Available Balance:" GridPane.rowIndex="1" />
                        <Label fx:id="accNumLabel" text="---" GridPane.columnIndex="1" />
                        <Label fx:id="balanceLabel" text="---" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     </children>
                  </GridPane>
                  <Label text="Transaction History">
                     <font><Font name="System Bold" size="14.0" /></font>
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                  </Label>
                  <ListView fx:id="transactionListView" prefHeight="300.0" VBox.vgrow="ALWAYS" />
               </children>
               <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
            </VBox>
         </content>
      </ScrollPane>
   </center>
   <bottom>
      <HBox fx:id="actionFooter" alignment="CENTER_LEFT" prefHeight="80.0" spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="amountInput" promptText="Enter amount..." />
            <Button mnemonicParsing="false" onAction="#handleDeposit" text="Deposit" />
            <Button mnemonicParsing="false" onAction="#handleWithdraw" text="Withdraw" />
            <Label fx:id="statusLabel" text="" />
         </children>
         <padding><Insets left="20.0" /></padding>
      </HBox>
   </bottom>
</BorderPane>