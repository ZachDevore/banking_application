            </Button>
            <Button fx:id="handleMoneyMarketBtn" mnemonicParsing="false" onAction="#handleMoneyMarketBtn" text="Money Market">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
      <ScrollPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
